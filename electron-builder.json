{
  "appId": "com.fintechdigital.app",
  "productName": "Fintech Digital",
  "artifactName": "Fintech.Digital-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "electron/**/*"
  ],
  "publish": {
    "provider": "github",
    "owner": "bonacciniWd",
    "repo": "FinanceDigital",
    "releaseType": "release"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "build/icon.icns",
    "category": "public.app-category.finance"
  },
  "win": {
    "target": ["nsis"],
    "icon": "build/icon.ico"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "build/icon.png",
    "category": "Finance"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}
