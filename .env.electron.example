# Copie este arquivo para .env.electron e preencha com seus valores reais.
# .env.electron é ignorado pelo git.
#
# Esses valores são usados pelo scripts/notarize.cjs durante o build local
# (npm run electron:publish OU ./scripts/release-local.sh).

# Apple ID (email)
APPLE_ID=seu-email@icloud.com

# App-Specific Password gerada em https://appleid.apple.com
# → Sign-In and Security → App-Specific Passwords → +
# Formato: xxxx-xxxx-xxxx-xxxx
APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Team ID (10 caracteres)
# https://developer.apple.com/account → Membership details
APPLE_TEAM_ID=ABCDE12345
